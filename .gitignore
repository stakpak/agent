# macOS
.DS_Store

# Xcode user-specific state (don't share between developers)
*.xcuserstate
*.xcuserdatad
xcuserdata/

# Editor backups
*.bak
*~
*.tmp
*.log
.gitignore~

# Swift Package Manager
.build/
.swiftpm/

# Build outputs
build/
DerivedData/
CompilationCache.noindex/
ModuleCache.noindex/
Intermediates.noindex/
**/DWARF/

# Binary distributables
*.dmg
*.app
*.ipa
*.xcarchive
*.dSYM
*.dSYM/

# Stray .app bundles dropped by the Copy Agent Resources build phase when
# its destination env var resolves to an integer (xcodebuild path quirk)
[0-9]/
[0-9][0-9]/

# Claude harness state
.claude/

# Playwright MCP cache
.playwright-mcp/

# Sensitive
ExportOptions.plist
