# macOS
.DS_Store

# Xcode user-specific state (don't share between developers)
*.xcuserstate
*.xcuserdatad
xcuserdata/

# Editor backups
*.bak
*~
*.tmp
*.log
.gitignore~

# Swift Package Manager
.build/
.swiftpm/

# Build outputs
build/
DerivedData/
CompilationCache.noindex/
ModuleCache.noindex/
Intermediates.noindex/
**/DWARF/

# Binary distributables
*.dmg
*.app
*.ipa
*.xcarchive
*.dSYM
*.dSYM/

# Stray .app bundles dropped by the Copy Agent Resources build phase when
# its destination env var resolves to an integer (xcodebuild path quirk)
[0-9]/
[0-9][0-9]/

# Claude harness state
.claude/

# Playwright MCP cache
.playwright-mcp/

# Sensitive
ExportOptions.plist

# Phantom Xcode workspace stub — the real project is ./Agent.xcodeproj.
# AgentXcode/ contains only an empty workspace shell with no project.pbxproj
# (probably created by an Xcode "Save As" or MCP tool that aborted halfway).
# Ignored so it doesn't drift back into the repo if it's recreated by Xcode.
AgentXcode/

# Plan-mode files written by the agent's plan_mode tool. These are
# scratchpad / working state, not source. Examples: plan_main.md,
# plan_archivexcode.md, plan_<task>.md.
plan*.md

# Per-project hidden dir used by every agent tool that writes to the
# project folder. Subdirs: .agent/index/ (project index), .agent/memory/
# (project-scoped memory), .agent/worktrees/ (git worktrees). One entry
# covers them all.
.agent/
